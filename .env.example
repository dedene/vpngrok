# Copy this to .env and fill in your VPN credentials.
#
# The vpn container runs gluetun, so any of its 40+ supported providers work.
# Variable names below are gluetun's own:
# https://github.com/qdm12/gluetun-wiki/tree/main/setup/providers

# Which provider to use (mullvad, nordvpn, protonvpn, surfshark, ...).
VPN_SERVICE_PROVIDER=mullvad

# wireguard or openvpn, depending on what your provider supports.
VPN_TYPE=wireguard

# --- WireGuard credentials (VPN_TYPE=wireguard) ---
# For Mullvad: generate a config at https://mullvad.net/en/account/wireguard-config
# and copy the PrivateKey and IPv4 Address values from it. Note that Mullvad
# rotates the keypair on every config download, so regenerating a config
# invalidates the key you had before.
WIREGUARD_PRIVATE_KEY=
WIREGUARD_ADDRESSES=

# --- OpenVPN credentials (VPN_TYPE=openvpn) ---
#OPENVPN_USER=
#OPENVPN_PASSWORD=

# Where the tunnel should exit. Pick a country where Grok is available for
# your account. Country names are provider-specific; gluetun's error message
# lists the valid ones if you guess wrong (Mullvad uses "USA", not
# "United States"). SERVER_CITIES is optional.
SERVER_COUNTRIES=USA
#SERVER_CITIES=

# Optional: auth Grok with an API key instead of the browser login flow.
#XAI_API_KEY=

# Optional: absolute path to the directory tree mounted into the dev container.
# The vpngrok wrapper works in any directory under this root.
# Defaults to $HOME/Development if unset. Use an absolute path, e.g. /Users/alice/Projects
#WORKSPACE_ROOT=

# Optional: timezone for container logs, e.g. Europe/Brussels.
#TZ=
